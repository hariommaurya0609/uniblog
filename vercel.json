{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push && next build",
  "framework": "nextjs",
  "functions": {
    "src/app/api/admin/scrape/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 */1 * * *"
    }
  ]
}
